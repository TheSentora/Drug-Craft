# Copy this file to `.env.local` and fill in your Supabase project values.
# Leave everything blank to run the game fully offline (localStorage only) —
# login and cloud saves just stay hidden until these are set.

# From Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by the admin dashboard. NEVER expose to the client.
# (Supabase → Project Settings → API → service_role secret)
SUPABASE_SERVICE_ROLE_KEY=

# Which account is allowed to open /admin (server-checked).
ADMIN_EMAIL=electroolite@gmail.com
# Same email, client-side, so the in-game "Admin" link only shows for you.
NEXT_PUBLIC_ADMIN_EMAIL=electroolite@gmail.com
