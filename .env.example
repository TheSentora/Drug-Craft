# Copy this file to `.env.local` and fill in your Supabase project values.
# Leave everything blank to run the game fully offline (localStorage only) —
# login and cloud saves just stay hidden until these are set.

# From Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by the admin dashboard. NEVER expose to the client.
# (Supabase → Project Settings → API → service_role secret)
SUPABASE_SERVICE_ROLE_KEY=

# Which account is allowed to open /admin (server-checked).
ADMIN_EMAIL=electroolite@gmail.com
# Same email, client-side, so the in-game "Admin" link only shows for you.
NEXT_PUBLIC_ADMIN_EMAIL=electroolite@gmail.com

# ---------------------------------------------------------------------------
# Withdrawal hot wallet (SERVER-ONLY). These pay real USDC out, so:
#   * NEVER prefix with NEXT_PUBLIC_ (that would ship the key to the browser).
#   * NEVER commit .env.local — only .env.example (this file) is tracked.
#   * On your host, set these as server env vars, not in the repo.
#   * Keep only small "float" amounts in the hot wallet.
# The private key is read ONLY inside a server API route, never client code.
# ---------------------------------------------------------------------------
# Solana keypair for the payout hot wallet (base58 secret key or JSON array).
HOT_WALLET_PRIVATE_KEY=
# RPC endpoint used to broadcast payouts.
SOLANA_RPC_URL=
# USDC mint address to send (Solana mainnet USDC by default).
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
